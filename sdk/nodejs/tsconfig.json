{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "apiBinding.ts",
        "config/index.ts",
        "config/vars.ts",
        "coreRuleConfig.ts",
        "externalLink.ts",
        "getConnector.ts",
        "getSpec.ts",
        "index.ts",
        "label.ts",
        "list.ts",
        "logBinding.ts",
        "monitor.ts",
        "notificationTemplate.ts",
        "provider.ts",
        "rule.ts",
        "ruleClientIdentifier.ts",
        "ruleClientIdentifierStorage.ts",
        "ruleDependencies.ts",
        "ruleScript.ts",
        "ruleScriptDependencies.ts",
        "ruleTestCase.ts",
        "spec.ts",
        "tagMetadata.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
